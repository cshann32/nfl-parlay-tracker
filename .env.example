# ─── Flask ────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-64-char-random-string

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://nfl:nflpassword@db:5432/nfl_tracker

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── NFL API (RapidAPI) ───────────────────────────────────
# NEVER commit the real key — keep in .env only
NFL_API_KEY=your-rapidapi-key-here
NFL_API_HOST_PRIMARY=nfl-football-api.p.rapidapi.com
NFL_API_HOST_FALLBACK=nfl-api-data.p.rapidapi.com
NFL_API_TIMEOUT=30
NFL_API_RETRY_COUNT=3

# ─── File Uploads ─────────────────────────────────────────
UPLOAD_FOLDER=/app/uploads
# 50 MB max upload size
MAX_CONTENT_LENGTH=52428800

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_DIR=/app/logs

# ─── Scheduler ────────────────────────────────────────────
# Keep false — enable only from admin panel
SCHEDULER_ENABLED=false
SYNC_INTERVAL_HOURS=24
